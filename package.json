{
  "name": "hexalith-polymorphic-serializations",
  "version": "0.0.0-development",
  "private": true,
  "description": "Hexalith Polymorphic Serializations libraries",
  "repository": {
    "type": "git",
    "url": "https://github.com/Hexalith/Hexalith.PolymorphicSerializations.git"
  },
  "release": {
    "extends": "./references/Hexalith.Builds/Github/package-release/release.config.json",
    "branches": [
      "+([0-9])?(.{+([0-9]),x}).x",
      "main",
      "next",
      "next-major",
      { "name": "beta", "prerelease": true },
      { "name": "alpha", "prerelease": true }
    ]
  },
  "devDependencies": {
    "@commitlint/cli": "^21.2.1",
    "@commitlint/config-conventional": "^21.1.0",
    "@semantic-release/changelog": "^7.0.0",
    "@semantic-release/exec": "^7.1.0",
    "@semantic-release/git": "^10.0.1",
    "@semantic-release/github": "^12.0.9",
    "semantic-release": "^25.0.7"
  }
}
